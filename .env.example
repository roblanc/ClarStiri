# Gemini API key — server-side ONLY, never prefix with VITE_
GEMINI_API_KEY=

# Upstash Redis (server-side only)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Your production domain (e.g. https://clarstiri.vercel.app)
# Used to restrict CORS to your own site. If unset, CORS defaults to '*'.
SITE_URL=
