# LLM providers — server-side ONLY, never prefix with VITE_
# Groq is the primary provider (30 RPM free tier, ~1s response)
# Get key at: https://console.groq.com
GROQ_API_KEY=

# Gemini is used as fallback when Groq is unavailable
# Get key at: https://aistudio.google.com
GEMINI_API_KEY=

# Upstash Redis (server-side only)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Required for /api/cron/refresh-news authentication in production.
CRON_SECRET=

# Your production domain (e.g. https://clarstiri.vercel.app)
# Used to restrict CORS to your own site. If unset, CORS defaults to '*'.
SITE_URL=

# Optional: protect /api/status in production.
# If omitted in production, the status endpoint is disabled.
STATUS_SECRET=
